// =====================
// PLAY COMMAND (DIRECT DOWNLOAD)
// =====================

bot.onText(/\/play (.+)/, async (msg, match) => {
  const chatId = msg.chat.id;
  const song = match[1]; // ✅ define FIRST

  const username =
    msg.from.username ||
    msg.from.first_name ||
    'unknown_user';

  const time = new Date().toLocaleString('en-IN', {
    timeZone: 'Asia/Kolkata',
    hour12: false
  });

  // ✅ LOG ENTRY
  fs.appendFileSync(LOG_FILE, `${time} | ${username} | ${song}\n`);

  const progressMsg = await bot.sendMessage(
    chatId,
    `🎵 Downloading: ${song}\n⬇️ 0%`
  );

  const yt = spawn('yt-dlp', [
    '-x',
    '--audio-format', 'mp3',
    '--progress-template', 'download:%(progress._percent_str)s',
    `ytsearch1:${song}`,
    '-o', `${DOWNLOAD_DIR}/%(title)s.%(ext)s`
  ]);

  yt.stdout.on('data', (data) => {
    const percent = data.toString().match(/(\d+(\.\d+)?%)/);
    if (percent) {
      bot.editMessageText(
        `🎵 Downloading: ${song}\n⬇️ ${percent[1]}`,
        { chat_id: chatId, message_id: progressMsg.message_id }
      ).catch(() => {});
    }
  });

  yt.on('close', async () => {
    const files = fs.readdirSync(DOWNLOAD_DIR).filter(f => f.endsWith('.mp3'));
    if (!files.length) return;

    const filePath = path.join(DOWNLOAD_DIR, files[0]);
    await bot.sendAudio(chatId, filePath);
    fs.unlinkSync(filePath);

    bot.editMessageText('✅ Download complete!', {
      chat_id: chatId,
      message_id: progressMsg.message_id
    });
  });
});



